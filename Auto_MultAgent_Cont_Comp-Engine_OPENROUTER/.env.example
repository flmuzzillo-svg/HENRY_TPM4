# ─────────────────────────────────────────────────────────────────────────────
# .env.example — LegalMove (OpenRouter): Agente Autónomo de Comparación de Contratos
# ─────────────────────────────────────────────────────────────────────────────
# Copiá este archivo como `.env` y completá los valores reales.
# NUNCA subas el archivo `.env` al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter (reemplaza a OpenAI — misma API, distinto proveedor)
OPENROUTER_API_KEY=sk-or-v1-...

# Langfuse (obtené las claves en https://cloud.langfuse.com → Settings → API Keys)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Modelos a utilizar (formato OpenRouter: proveedor/modelo)
# Opciones: openai/gpt-4o | openai/gpt-4o-mini | google/gemini-2.0-flash-001 | anthropic/claude-sonnet-4
LLM_MODEL=openai/gpt-4o
VISION_MODEL=openai/gpt-4o
